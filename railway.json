{
    "$schema": "https://railway.app/railway.schema.json",
    "services": {
        "mais-api": {
            "name": "mais-api",
            "root": "/",
            "source": {
                "repo": "mais_esportes_incentivo"
            },
            "build": {
                "builder": "NIXPACKS",
                "buildCommand": "npx turbo run build --filter=@mais-futebol/api",
                "watchPatterns": [
                    "apps/api/**",
                    "packages/**"
                ]
            },
            "deploy": {
                "startCommand": "node apps/api/dist/apps/api/src/main.js",
                "healthcheckPath": "/",
                "restartPolicy": "ON_FAILURE"
            }
        },
        "mais-web": {
            "name": "mais-web",
            "root": "/",
            "source": {
                "repo": "mais_esportes_incentivo"
            },
            "build": {
                "builder": "NIXPACKS",
                "buildCommand": "npx turbo run build --filter=@mais-futebol/web",
                "watchPatterns": [
                    "apps/web/**",
                    "packages/**"
                ]
            },
            "deploy": {
                "startCommand": "npx turbo run start --filter=@mais-futebol/web",
                "healthcheckPath": "/",
                "restartPolicy": "ON_FAILURE"
            }
        }
    }
}